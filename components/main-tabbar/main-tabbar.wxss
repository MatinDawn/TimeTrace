.tabbar {
  position: fixed;
  left: 22rpx;
  right: 22rpx;
  bottom: 16rpx;
  z-index: 30;
  display: flex;
  padding: 14rpx 10rpx 18rpx;
  border-radius: 40rpx;
  background: rgba(255, 250, 243, 0.94);
  border: 1rpx solid rgba(255, 255, 255, 0.9);
  box-shadow: 0 24rpx 54rpx rgba(84, 63, 42, 0.12);
  backdrop-filter: blur(20rpx);
}

.tabbar-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 10rpx 0;
  color: #8e8071;
  font-size: 20rpx;
}

.tabbar-item.active {
  color: #2d6b4b;
}

.tabbar-label {
  font-size: 26rpx;
  font-weight: 600;
  line-height: 1.18;
}

.tabbar-item.active .tabbar-label {
  font-weight: 700;
}

.tabbar-sub {
  font-size: 20rpx;
  line-height: 1.1;
}
