.composer-card {
  margin-top: 28rpx;
  padding: 22rpx;
  border-radius: 28rpx;
  background: #f8f0e3;
}

.composer-input-wrap,
.voice-input-wrap {
  min-height: 300rpx;
  border-radius: 24rpx;
  background: #fffaf2;
}

.record-textarea {
  width: 100%;
  height: 300rpx;
  box-sizing: border-box;
  padding: 24rpx;
  font-size: 28rpx;
}

.voice-input-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  box-sizing: border-box;
}

.voice-hint {
  font-size: 28rpx;
  font-weight: 600;
  color: #4f3f2f;
}

.voice-button {
  min-width: 320rpx;
  height: 96rpx;
  margin-top: 24rpx;
  padding: 0 30rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #2c6e49;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
}

.voice-tip {
  margin-top: 18rpx;
  font-size: 22rpx;
  color: #8d7760;
}

.composer-toolbar {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
  padding: 10rpx 6rpx 0;
}

.tool-icon {
  min-width: 112rpx;
  height: 60rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #efe4d4;
  color: #5f4b37;
  font-size: 24rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.toolbar-text {
  font-size: 24rpx;
  color: #8d7760;
}

.example-title {
  margin-top: 28rpx;
  font-size: 26rpx;
  font-weight: 600;
}

.example-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 18rpx;
}

.example-chip {
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: #efe4d4;
  color: #6f5a46;
  font-size: 24rpx;
}

.save-button {
  margin-top: 32rpx;
  width: 100%;
}
