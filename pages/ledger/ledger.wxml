<view class="page">
  <view class="hero">
    <view class="hero-title">记一笔</view>
    <view class="hero-subtitle">直接输入自然语言，留痕会自动识别金额、日期、分类和统计意图。</view>
  </view>

  <view class="section card">
    <view class="section-title">自然语言输入</view>
    <textarea
      class="textarea"
      placeholder="比如：晚饭花了52元"
      value="{{inputText}}"
      bindinput="onInput"
    />
    <button class="primary-btn" bindtap="submitText">解析并执行</button>
  </view>

  <view class="section card">
    <view class="section-title">示例</view>
    <view class="chip-row">
      <view
        wx:for="{{examples}}"
        wx:key="*this"
        class="chip"
        data-value="{{item}}"
        bindtap="fillExample"
      >
        {{item}}
      </view>
    </view>
  </view>

  <view wx:if="{{latestResult}}" class="section card">
    <view class="section-title">执行结果</view>
    <view class="hero-subtitle">{{latestResult}}</view>
  </view>
</view>
