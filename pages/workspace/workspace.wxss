.mode-card {
  margin-top: 22rpx;
}

.mode-title,
.space-meta {
  font-size: 24rpx;
  color: var(--ink-500);
}

.mode-name {
  margin-top: 10rpx;
  font-family: "STKaiti", "Kaiti SC", "Songti SC", serif;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--ink-800);
}

.mode-hint {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7f6a55;
}

.invite-line,
.space-meta-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.invite-line {
  margin-top: 10rpx;
}

.invite-label,
.invite-code {
  font-size: 24rpx;
  line-height: 1.7;
  color: #7f6a55;
}

.invite-label::after {
  content: ":";
}

.invite-code {
  font-weight: 600;
  letter-spacing: 1rpx;
  color: #5f4d3c;
}

.secondary-button,
.action-button,
.small-button {
  border: none;
}

.secondary-button,
.action-button {
  width: 100%;
  margin-top: 20rpx;
}

.spaces-card {
  padding-bottom: 26rpx;
}

.spaces-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.add-space-button {
  position: relative;
  z-index: 1;
  width: 58rpx;
  height: 58rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  color: #4f3f31;
  font-size: 52rpx;
  font-weight: 300;
  line-height: 1;
  background: rgba(255, 251, 245, 0.62);
}

.space-panel {
  position: relative;
  z-index: 1;
  margin-top: 18rpx;
  padding: 24rpx 22rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.82);
  background:
    linear-gradient(135deg, rgba(255, 247, 237, 0.94) 0%, rgba(242, 231, 214, 0.84) 100%);
  box-shadow:
    0 14rpx 34rpx rgba(83, 63, 42, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.85);
}

.space-panel:nth-child(3n) {
  background:
    linear-gradient(135deg, rgba(247, 239, 227, 0.94) 0%, rgba(232, 224, 211, 0.82) 100%);
}

.space-panel.active {
  background:
    linear-gradient(135deg, rgba(232, 242, 231, 0.94) 0%, rgba(218, 229, 213, 0.86) 100%);
}

.space-top-row,
.space-bottom-row {
  display: flex;
  align-items: center;
  min-width: 0;
}

.space-top-row {
  justify-content: space-between;
  gap: 18rpx;
}

.space-bottom-row {
  margin-top: 16rpx;
  justify-content: space-between;
  gap: 12rpx;
}

.space-name-row {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.space-name {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink-800);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.active-tag {
  flex-shrink: 0;
  padding: 7rpx 13rpx;
  border-radius: 999rpx;
  background: rgba(227, 240, 231, 0.92);
  color: var(--green-700);
  font-size: 22rpx;
}

.invite-chip {
  flex: 1;
  min-width: 0;
  padding: 0;
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #5f4d3c;
  font-size: 22rpx;
  line-height: 1.2;
}

.invite-text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.space-chevron {
  width: 18rpx;
  height: 18rpx;
  flex-shrink: 0;
  border-top: 3rpx solid rgba(116, 93, 68, 0.46);
  border-right: 3rpx solid rgba(116, 93, 68, 0.46);
  transform: rotate(45deg);
}

.member-ring {
  position: relative;
  width: 82rpx;
  height: 82rpx;
  flex-shrink: 0;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #4f3f31;
  background:
    radial-gradient(circle at center, rgba(255, 251, 245, 0.96) 0 54%, transparent 55%),
    conic-gradient(#6c9a72 0 72deg, rgba(255, 251, 245, 0.86) 72deg 360deg);
  box-shadow: inset 0 0 0 10rpx rgba(255, 251, 245, 0.66);
}

.member-count {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1;
}

.member-label {
  margin-top: 5rpx;
  font-size: 18rpx;
  line-height: 1;
}

.copy-icon-button {
  position: relative;
  width: 44rpx;
  height: 44rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: rgba(247, 239, 227, 0.86);
}

.copy-icon-button.subtle {
  width: 40rpx;
  height: 40rpx;
  background: transparent;
}

.copy-icon,
.copy-icon::before {
  position: absolute;
  width: 20rpx;
  height: 22rpx;
  border: 3rpx solid #9b7c58;
  border-radius: 5rpx;
  box-sizing: border-box;
}

.copy-icon {
  left: 13rpx;
  top: 10rpx;
}

.copy-icon::before {
  content: "";
  left: -8rpx;
  top: 6rpx;
  border-color: rgba(155, 124, 88, 0.58);
  background: rgba(255, 250, 243, 0.6);
}

.sheet-mask {
  position: fixed;
  z-index: 20;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  display: flex;
  align-items: flex-end;
  background: rgba(45, 40, 34, 0.32);
}

.space-sheet {
  width: 100%;
  padding: 18rpx 34rpx 56rpx;
  border-radius: 42rpx 42rpx 0 0;
  background: #fffbf5;
  box-shadow: 0 -18rpx 48rpx rgba(66, 49, 31, 0.16);
}

.sheet-grabber {
  width: 96rpx;
  height: 10rpx;
  margin: 0 auto 34rpx;
  border-radius: 999rpx;
  background: rgba(118, 101, 84, 0.18);
}

.sheet-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-800);
}

.sheet-subtitle {
  margin-top: 12rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7f6a55;
}

.sheet-input {
  margin-top: 28rpx;
  border: 1rpx solid rgba(158, 128, 94, 0.18);
  background: rgba(247, 239, 227, 0.58);
}
