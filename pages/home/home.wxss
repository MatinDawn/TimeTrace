.home-screen {
  padding-top: 0;
  padding-bottom: var(--screen-bottom-pad);
}

.custom-nav,
.scope-button,
.quote-card,
.progress-total,
.hero-stage,
.hero-side,
.hero-hint-bar,
.tab-row {
  display: flex;
}

.custom-nav {
  position: relative;
  z-index: 3;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.nav-row {
  display: flex;
  align-items: center;
}

.nav-row-title {
  justify-content: center;
}

.nav-row-actions {
  justify-content: space-between;
  gap: 16rpx;
  padding: 4rpx 0 6rpx;
}

.nav-brand-title {
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 40rpx;
  line-height: 1.1;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: var(--ink-900);
}

.scope-button {
  align-items: center;
  gap: 12rpx;
  width: 260rpx;
  height: 96rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 249, 240, 0.88);
  border: 1rpx solid rgba(224, 206, 180, 0.3);
  box-shadow: 0 12rpx 28rpx rgba(105, 82, 59, 0.06);
  box-sizing: border-box;
}

.scope-sprout {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.sprout-stem {
  position: absolute;
  left: 14rpx;
  bottom: 3rpx;
  width: 3rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #7f9c67;
}

.sprout-leaf {
  position: absolute;
  width: 14rpx;
  height: 9rpx;
  border-radius: 14rpx 14rpx 0 14rpx;
  background: linear-gradient(180deg, #adc589 0%, #7f9c67 100%);
}

.sprout-left {
  left: 1rpx;
  top: 10rpx;
  transform: rotate(-36deg);
}

.sprout-right {
  right: 2rpx;
  top: 5rpx;
  transform: scaleX(-1) rotate(-36deg);
}

.scope-copy {
  min-width: 0;
  flex: 1;
}

.scope-button-label {
  font-size: 20rpx;
  color: var(--ink-300);
}

.scope-button-text {
  margin-top: 4rpx;
  max-width: 150rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 28rpx;
  font-weight: 600;
  color: #5b4b3d;
}

.scope-chevron {
  width: 12rpx;
  height: 12rpx;
  border-right: 2rpx solid #a08567;
  border-bottom: 2rpx solid #a08567;
  transform: rotate(45deg);
  margin-top: -6rpx;
}

.intro-row {
  display: none;
}

/* 山水图上叠加的动态文案层（AI 总结 / 文艺短句）
   task-overview-illustration.svg viewBox 1000x500，山在右下，
   左上是引号装饰，文字紧贴引号下方留白错落排版 */
.quote-text-layer {
  position: absolute;
  left: 16%;
  right: 32%;
  top: 28%;
  bottom: 24%;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: flex-start;
  gap: 18rpx;
  pointer-events: none;
  z-index: 1;
}

.quote-line {
  font-family: "STKaiti", "Kaiti SC", "Songti SC", serif;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f1a17;
  letter-spacing: 0;
  line-height: 1.32;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.quote-line.line1 {
  /* 第一行靠左起笔 */
  margin-left: 0;
}

.quote-line.line2 {
  /* 第二句向右错开约一字宽，形成书法错落感 */
  color: #3a322a;
  margin-left: 72rpx;
  max-width: calc(100% - 72rpx);
}

/* AI 来源时给一个极淡的"墨痕"渐变区分（可选视觉提示） */
.quote-text-layer.is-ai .quote-line {
  background: linear-gradient(90deg, #1f1a17 0%, #3a6b53 100%);
  -webkit-background-clip: text;
  background-clip: text;
  -webkit-text-fill-color: transparent;
}

.draft-entry {
  width: 260rpx;
  height: 96rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  background: rgba(255, 248, 238, 0.92);
  border: 1rpx solid rgba(224, 206, 180, 0.34);
  color: #7f684d;
  font-size: 28rpx;
  box-shadow: 0 14rpx 34rpx rgba(111, 86, 59, 0.06);
  box-sizing: border-box;
}

.nav-draft {
  flex-shrink: 0;
}

.draft-icon {
  width: 72rpx;
  height: 72rpx;
  display: block;
  flex-shrink: 0;
}

.draft-label {
  color: #7f684d;
  font-weight: 600;
}

.draft-count {
  color: #ad9476;
}

.progress-card {
  margin-top: 24rpx;
  padding-bottom: 32rpx;
}

.progress-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.with-info {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.info-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #a89479;
  border: 2rpx solid rgba(192, 177, 155, 0.66);
}

.progress-bubble {
  width: 188rpx;
  padding: 14rpx 16rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(249, 239, 223, 0.92) 0%, rgba(244, 229, 208, 0.92) 100%);
  color: #7f6649;
  font-size: 21rpx;
  line-height: 1.55;
  flex-shrink: 0;
}

.progress-main {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  padding-right: 70rpx;
}

.progress-total {
  align-items: flex-end;
  gap: 10rpx;
  flex-wrap: wrap;
  color: var(--ink-900);
}

.progress-number {
  font-size: 64rpx;
  line-height: 1;
  color: var(--green-700);
}

.progress-separator,
.progress-target {
  font-size: 30rpx;
  line-height: 1.2;
}

.progress-unit {
  margin-left: 6rpx;
  font-size: 25rpx;
  line-height: 1.2;
}

.progress-track-shell {
  margin-top: 30rpx;
  padding: 0 36rpx;
}

/* ===== 进度条上方目标提示 ===== */
.progress-goal-hint {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.45;
  text-align: center;
  color: var(--ink-500, #8a7a64);
  letter-spacing: 0.4rpx;
  transition: color 0.3s ease;
}

.progress-goal-hint .progress-goal-icon {
  font-size: 22rpx;
  flex-shrink: 0;
}

.progress-goal-copy {
  min-width: 0;
  max-width: calc(100% - 34rpx);
  line-height: 1.45;
  text-align: center;
  word-break: break-word;
}

.progress-goal-hint.beyond {
  color: #2d6b4b;
  font-weight: 600;
  animation: progressGoalCelebrate 0.6s ease-out;
}

@keyframes progressGoalCelebrate {
  0% {
    transform: scale(0.92);
    opacity: 0.4;
  }
  60% {
    transform: scale(1.06);
    opacity: 1;
  }
  100% {
    transform: scale(1);
    opacity: 1;
  }
}

.progress-track-line {
  position: relative;
  height: 124rpx;
  margin-top: 4rpx;
  border-radius: 999rpx;
}

.progress-track-line::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 106rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #d9cdbc;
  transform: translateY(-50%);
}

.progress-segment {
  position: absolute;
  top: 106rpx;
  width: 50%;
  height: 4rpx;
  z-index: 1;
  border-radius: 999rpx;
  background: #d9cdbc;
  transform: translateY(-50%);
}

.progress-segment.left {
  left: 0;
}

.progress-segment.right {
  left: 50%;
}

.progress-segment.done {
  background: linear-gradient(90deg, #7fa86d 0%, #2d6b4b 100%);
}

/* ===== 超额状态：整条进度条转绿 + 终点脉冲 ===== */
.progress-track-line.beyond .progress-segment {
  background: linear-gradient(90deg, #7fa86d 0%, #2d6b4b 100%);
}

.progress-track-line.beyond::before {
  background: linear-gradient(90deg, #7fa86d 0%, #2d6b4b 100%);
}

.progress-node.beyond {
  border-color: #2d6b4b;
  background: #fffdf2;
  box-shadow: 0 0 0 0 rgba(45, 107, 75, 0.6);
  animation: progressNodePulse 1.6s ease-in-out infinite;
}

@keyframes progressNodePulse {
  0%,
  100% {
    box-shadow: 0 0 0 0 rgba(45, 107, 75, 0.55);
  }
  50% {
    box-shadow: 0 0 0 14rpx rgba(45, 107, 75, 0);
  }
}

.progress-node,
.progress-node-label,
.progress-indicator {
  position: absolute;
  transform: translate(-50%, -50%);
}

.progress-node {
  z-index: 3;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #fffaf2;
  border: 5rpx solid #d9cdbc;
  box-shadow: 0 6rpx 14rpx rgba(83, 63, 42, 0.08);
  top: 106rpx;
}

.progress-node.done {
  border-color: #72a061;
  background: #f3faee;
  box-shadow: 0 8rpx 18rpx rgba(45, 107, 75, 0.14);
}

.progress-node.left {
  left: 0;
}

.progress-node.right {
  left: 100%;
}

.progress-node.middle {
  left: 50%;
}

.progress-node-label {
  top: 134rpx;
  z-index: 3;
  color: #a18b73;
  font-size: 20rpx;
  line-height: 1;
  white-space: nowrap;
}

.progress-node-label.left {
  left: 0;
}

.progress-node-label.middle {
  left: 50%;
}

.progress-node-label.right {
  left: 100%;
}

.progress-indicator {
  z-index: 4;
  width: 64rpx;
  height: 64rpx;
  top: 76rpx;
  transition: left 0.24s ease;
  pointer-events: none;
}

.progress-mascot {
  position: absolute;
  inset: 0;
  overflow: visible;
}

.progress-mascot-image {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 54rpx;
  height: 68rpx;
  transform: translate(-50%, -70%);
}

.progress-tree-zone {
  position: absolute;
  right: -6rpx;
  bottom: 18rpx;
  width: 118rpx;
  height: 142rpx;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
}

.progress-tree {
  position: relative;
  width: 112rpx;
  height: 140rpx;
  transform-origin: 50% 100%;
}

.ink-tree-soil {
  position: absolute;
  left: 12rpx;
  right: 8rpx;
  bottom: 0;
  height: 14rpx;
  border-radius: 50%;
  background: radial-gradient(ellipse at center, rgba(58, 58, 58, 0.22) 0%, rgba(141, 111, 76, 0.18) 50%, rgba(217, 193, 159, 0) 78%);
  z-index: 1;
}

.ink-tree-image {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  width: 100%;
  height: 100%;
  z-index: 2;
  transition: clip-path 0.9s cubic-bezier(0.2, 0.8, 0.2, 1),
    transform 0.6s cubic-bezier(0.2, 0.8, 0.2, 1),
    opacity 0.5s ease;
  transform-origin: 50% 100%;
}

.progress-tree.stage-0 .ink-tree-image {
  clip-path: inset(100% 36% 0 36%);
  -webkit-clip-path: inset(100% 36% 0 36%);
  opacity: 0.15;
}

.progress-tree.stage-1 .ink-tree-image {
  clip-path: inset(58% 28% 0 28%);
  -webkit-clip-path: inset(58% 28% 0 28%);
  opacity: 0.85;
}

.progress-tree.stage-2 .ink-tree-image {
  clip-path: inset(28% 8% 0 8%);
  -webkit-clip-path: inset(28% 8% 0 8%);
  opacity: 0.95;
}

.progress-tree.stage-3 .ink-tree-image {
  clip-path: inset(0 0 0 0);
  -webkit-clip-path: inset(0 0 0 0);
  opacity: 1;
}

.progress-tree.growing .ink-tree-image {
  animation: inkTreeReveal 1s cubic-bezier(0.2, 0.8, 0.2, 1) both;
}

.progress-tree.stage-3.growing,
.progress-tree.complete {
  animation: treeGentleSway 1.7s ease-in-out 0.7s;
}

@keyframes inkTreeReveal {
  0% {
    transform: scale(0.82) translateY(8rpx);
    opacity: 0.3;
  }
  60% {
    transform: scale(1.04) translateY(-2rpx);
    opacity: 1;
  }
  100% {
    transform: scale(1) translateY(0);
    opacity: 1;
  }
}

@keyframes treeGentleSway {
  0%,
  100% {
    transform: rotate(0deg);
  }
  35% {
    transform: rotate(-2deg);
  }
  70% {
    transform: rotate(2deg);
  }
}

.hero-card {
  margin-top: 24rpx;
}

.hero-stage {
  position: relative;
  min-height: 404rpx;
}

.hero-button {
  position: relative;
  width: 356rpx;
  height: 356rpx;
  margin: 0 auto;
  border-radius: 50%;
  padding: 14rpx;
  background: linear-gradient(180deg, #f2d7b5 0%, #ddbf98 100%);
  box-shadow: 0 26rpx 52rpx rgba(103, 81, 53, 0.16);
  transition: transform 0.28s cubic-bezier(0.34, 1.56, 0.64, 1),
    box-shadow 0.28s ease;
  animation: heroBreath 4.2s ease-in-out infinite;
  z-index: 1;
}

.hero-button.recording {
  animation: none;
  transform: scale(1.04);
  box-shadow:
    0 30rpx 60rpx rgba(45, 107, 75, 0.24),
    0 0 0 16rpx rgba(45, 107, 75, 0.08);
}

.hero-button.pressed {
  animation: none;
  transform: scale(0.94);
  box-shadow:
    0 12rpx 26rpx rgba(45, 107, 75, 0.2),
    inset 0 6rpx 18rpx rgba(0, 0, 0, 0.18);
}

.hero-button.loading,
.hero-button.success {
  animation: none;
}

@keyframes heroBreath {
  0%,
  100% {
    box-shadow: 0 26rpx 52rpx rgba(103, 81, 53, 0.16),
      0 0 0 0 rgba(127, 168, 109, 0);
  }
  50% {
    box-shadow: 0 30rpx 58rpx rgba(103, 81, 53, 0.2),
      0 0 0 14rpx rgba(127, 168, 109, 0.08);
  }
}

/* ===== 波纹层 ===== */
.hero-ripple-layer {
  position: absolute;
  inset: 0;
  border-radius: 50%;
  pointer-events: none;
  z-index: 0;
}

.hero-ripple {
  position: absolute;
  inset: 0;
  margin: auto;
  border-radius: 50%;
  border: 3rpx solid rgba(45, 107, 75, 0.5);
  opacity: var(--ripple-opacity, 0.5);
  transform: scale(var(--ripple-scale, 1));
  transition: transform 0.45s ease-out, opacity 0.45s ease-out;
}

/* ===== 麦克风图标（按下/录音中可见） ===== */
.hero-mic-core {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  opacity: 0;
  transform: scale(0.6);
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.hero-leaf.mic .hero-leaf-core {
  opacity: 0;
  transform: rotate(-28deg) scale(0.6);
}

.hero-leaf.mic .hero-mic-core {
  opacity: 1;
  transform: scale(1);
}

.hero-mic-body {
  width: 22rpx;
  height: 32rpx;
  border-radius: 12rpx;
  background: #fffdf5;
  box-shadow: 0 2rpx 6rpx rgba(0, 0, 0, 0.18);
}

.hero-mic-base {
  width: 28rpx;
  height: 6rpx;
  margin-top: 4rpx;
  border-radius: 4rpx;
  background: rgba(255, 253, 245, 0.85);
  position: relative;
}

.hero-mic-base::before {
  content: "";
  position: absolute;
  left: 50%;
  top: -8rpx;
  width: 2rpx;
  height: 8rpx;
  background: rgba(255, 253, 245, 0.85);
  transform: translateX(-50%);
}

/* ===== 加载环 ===== */
.hero-loading-ring {
  position: absolute;
  inset: 6rpx;
  border-radius: 50%;
  border: 6rpx solid rgba(45, 107, 75, 0.16);
  border-top-color: #2d6b4b;
  border-right-color: #2d6b4b;
  pointer-events: none;
  animation: heroLoadingSpin 0.9s linear infinite;
  z-index: 4;
}

@keyframes heroLoadingSpin {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}

/* ===== 成功爆开 ===== */
.hero-success-burst {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
  animation: heroSuccessBurst 0.8s ease-out forwards;
}

.hero-success-icon {
  font-size: 96rpx;
  filter: drop-shadow(0 4rpx 12rpx rgba(255, 220, 120, 0.6));
}

@keyframes heroSuccessBurst {
  0% {
    transform: scale(0.2);
    opacity: 0;
  }
  35% {
    transform: scale(1.2);
    opacity: 1;
  }
  100% {
    transform: scale(1);
    opacity: 0.95;
  }
}

.hero-button-ring {
  width: 100%;
  height: 100%;
  padding: 12rpx;
  border-radius: 50%;
  background: rgba(255, 247, 235, 0.3);
}

.hero-button-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 0;
  background: radial-gradient(circle at 30% 20%, #418960 0%, #2d6b4b 56%, #214c38 100%);
  color: #fffdf8;
  text-align: center;
}

.hero-leaf {
  position: relative;
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.16);
}

.hero-leaf-core {
  position: relative;
  width: 23rpx;
  height: 32rpx;
  border-radius: 20rpx 20rpx 0 20rpx;
  background: #fffdf5;
  transform: rotate(-28deg);
  transition: opacity 0.2s ease, transform 0.2s ease;
}

.hero-leaf-core::after {
  content: "";
  position: absolute;
  left: 9rpx;
  top: 2rpx;
  width: 2rpx;
  height: 26rpx;
  background: rgba(45, 107, 75, 0.32);
  transform: rotate(28deg);
}

.hero-title {
  margin-top: 30rpx;
  width: 292rpx;
  padding: 0;
  font-family: "STKaiti", "Kaiti SC", "Songti SC", serif;
  font-size: 88rpx;
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: 12rpx;
  text-align: center;
  text-indent: 12rpx;
  white-space: nowrap;
  /* 防止周边动画引起的字符亚像素抖动 */
  will-change: transform;
  transform: translateZ(0);
  backface-visibility: hidden;
  -webkit-font-smoothing: antialiased;
}

/* 录音中状态文案较长，需要恢复较小字号避免溢出 */
.hero-title.is-listening {
  font-size: 36rpx;
  letter-spacing: 0;
  text-indent: 0;
  line-height: 1.3;
}

.hero-voice-status {
  max-width: 250rpx;
  min-height: 42rpx;
  margin-top: 16rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: rgba(255, 253, 248, 0.16);
  color: rgba(255, 253, 248, 0.92);
  font-size: 21rpx;
  line-height: 1.3;
  white-space: nowrap;
  overflow: hidden;
}

.hero-voice-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
  flex-shrink: 0;
  animation: voicePulse 1s ease-in-out infinite;
}

.hero-voice-status text {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
}

.hero-subtitle {
  display: none;
}

.hero-side {
  position: absolute;
  top: 134rpx;
  width: 124rpx;
  flex-direction: column;
  gap: 6rpx;
  color: #5f5144;
  font-size: 21rpx;
  line-height: 1.8;
}

.hero-side.left {
  left: 0;
}

.hero-side.right {
  right: 0;
  align-items: flex-end;
  text-align: right;
  width: 138rpx;
}

.hero-dashed {
  width: 48rpx;
  height: 22rpx;
  border-top: 3rpx dashed rgba(145, 122, 95, 0.8);
  border-right: 3rpx dashed rgba(145, 122, 95, 0.8);
  border-radius: 0 30rpx 0 0;
}

.hero-dashed.left {
  transform: rotate(10deg);
}

.hero-plane-image {
  width: 60rpx;
  margin-bottom: 6rpx;
}

.hero-hint-bar {
  margin-top: 22rpx;
  min-height: 80rpx;
  padding: 0 22rpx;
  align-items: center;
  justify-content: space-between;
  border-radius: 999rpx;
  background: rgba(252, 246, 235, 0.95);
  color: #7d694f;
  font-size: 23rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.75);
}

.hero-progress {
  position: relative;
  margin-top: 24rpx;
  padding: 8rpx 70rpx 36rpx 0;
}

.hint-sprout {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.hint-stem {
  position: absolute;
  left: 14rpx;
  bottom: 3rpx;
  width: 3rpx;
  height: 16rpx;
  background: #7ea05d;
  border-radius: 999rpx;
}

.hint-leaf {
  position: absolute;
  width: 13rpx;
  height: 8rpx;
  border-radius: 13rpx 13rpx 0 13rpx;
  background: linear-gradient(180deg, #a8c487 0%, #79995a 100%);
}

.hint-leaf.left {
  left: 2rpx;
  top: 10rpx;
  transform: rotate(-28deg);
}

.hint-leaf.right {
  right: 2rpx;
  top: 5rpx;
  transform: scaleX(-1) rotate(-28deg);
}

.hint-arrow {
  width: 14rpx;
  height: 14rpx;
  border-top: 2rpx solid #a48c6f;
  border-right: 2rpx solid #a48c6f;
  transform: rotate(45deg);
}

.overview-card {
  margin-top: 24rpx;
  padding-bottom: 42rpx;
}

.empty-text {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  padding: 34rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(249, 243, 233, 0.86);
  color: #8d7a65;
  font-size: 24rpx;
  line-height: 1.7;
  text-align: center;
}

.overview-pill {
  min-width: 90rpx;
  height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(247, 238, 224, 0.94);
  color: #9b8366;
  font-size: 23rpx;
}

.tab-row {
  gap: 16rpx;
  margin-top: 24rpx;
}

.feed-tab {
  flex: 1;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #f7eee0 0%, #efdfca 100%);
  color: #8a6f52;
  font-size: 24rpx;
  font-weight: 600;
}

.feed-tab.active {
  background: linear-gradient(180deg, #5a9670 0%, #2d6b4b 100%);
  color: #fffef8;
}

/* .feed-item 共性 (display/align/justify/gap/padding/border-bottom) 来自 .list-row */
.feed-item:last-of-type {
  border-bottom: none;
}

.feed-icon {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(247, 238, 224, 0.95) 0%, rgba(240, 226, 205, 0.95) 100%);
  position: relative;
}

.feed-icon.sprout::before,
.feed-icon.sprout::after,
.feed-icon.hourglass::before,
.feed-icon.hourglass::after {
  content: "";
  position: absolute;
}

.feed-icon.sprout::before {
  left: 33rpx;
  top: 24rpx;
  width: 4rpx;
  height: 22rpx;
  background: #7ea05d;
}

.feed-icon.sprout::after {
  left: 20rpx;
  top: 14rpx;
  width: 28rpx;
  height: 18rpx;
  border-radius: 28rpx 28rpx 0 28rpx;
  background: linear-gradient(180deg, #99b876 0%, #73955a 100%);
  transform: rotate(-18deg);
}

.feed-icon.hourglass::before {
  left: 24rpx;
  top: 14rpx;
  width: 22rpx;
  height: 40rpx;
  border: 4rpx solid #b88b55;
  border-top-width: 6rpx;
  border-bottom-width: 6rpx;
  border-radius: 12rpx;
  transform: skewY(12deg);
}

.feed-icon.hourglass::after {
  left: 32rpx;
  top: 28rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #b88b55;
}

.feed-main {
  flex: 1;
  min-width: 0;
}

.feed-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #302821;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feed-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8d7a65;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feed-creator {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: #9a7f61;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feed-side {
  flex-shrink: 0;
  max-width: 170rpx;
  text-align: right;
  font-size: 22rpx;
  font-weight: 600;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.feed-side.pending {
  color: #a27742;
}

.feed-side-stack {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 10rpx;
}

.feed-quick-trace {
  min-width: 132rpx;
  height: 54rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #5a9670 0%, #2d6b4b 100%);
  color: #fffef8;
  font-size: 21rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.feed-side.done-amount {
  color: var(--green-700);
}

.feed-side.done-text {
  color: #7c9664;
}

.overview-quote {
  margin-top: 18rpx;
  text-align: center;
  font-size: 23rpx;
  line-height: 1.8;
  color: #6e5b48;
}

.overview-line-image {
  width: 116rpx;
  margin: 10rpx auto 0;
}

.overview-illustration-wrap {
  position: relative;
  z-index: 1;
  width: 100%;
  margin-top: 12rpx;
}

.overview-illustration {
  position: relative;
  z-index: 1;
  width: 100%;
  display: block;
  border-radius: 28rpx;
}

.trace-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  display: flex;
  align-items: flex-end;
  background: rgba(29, 28, 25, 0.48);
  backdrop-filter: blur(14rpx);
}

.trace-sheet {
  width: 100%;
  min-height: 690rpx;
  padding: 46rpx 46rpx calc(54rpx + env(safe-area-inset-bottom));
  border-radius: 56rpx 56rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -24rpx 70rpx rgba(29, 28, 25, 0.16);
}

.sheet-handle {
  width: 92rpx;
  height: 12rpx;
  margin: 0 auto 54rpx;
  border-radius: 999rpx;
  background: #e1e4e9;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.sheet-title {
  flex: 1;
  min-width: 0;
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #30343a;
}

.sheet-close {
  position: relative;
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #f3f4f6;
}

.sheet-close::before,
.sheet-close::after {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 32rpx;
  width: 26rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #6f7682;
}

.sheet-close::before {
  transform: rotate(45deg);
}

.sheet-close::after {
  transform: rotate(-45deg);
}

.sheet-editor {
  margin-top: 46rpx;
  padding: 34rpx 40rpx 26rpx;
  border-radius: 38rpx;
  background: #fbfbfc;
  box-shadow:
    0 14rpx 34rpx rgba(28, 31, 36, 0.08),
    inset 0 0 0 2rpx rgba(235, 238, 242, 0.8);
}

.sheet-textarea {
  width: 100%;
  height: 520rpx;
  color: #30343a;
  font-size: 30rpx;
  line-height: 1.7;
}

.sheet-textarea::placeholder {
  color: #9aa3b2;
}

/* ===== 进度条光点飞行 ===== */
.progress-spark {
  position: absolute;
  top: 50%;
  width: 18rpx;
  height: 18rpx;
  margin-top: -9rpx;
  border-radius: 50%;
  background: #ffe8a3;
  box-shadow:
    0 0 12rpx 6rpx rgba(255, 232, 163, 0.75),
    0 0 24rpx 10rpx rgba(255, 210, 120, 0.45);
  pointer-events: none;
  animation: progressSparkFly 0.9s cubic-bezier(0.4, 0, 0.2, 1) forwards;
  z-index: 3;
}

@keyframes progressSparkFly {
  0% {
    left: var(--spark-from, 0%);
    transform: scale(0.4);
    opacity: 0;
  }
  15% {
    transform: scale(1.2);
    opacity: 1;
  }
  100% {
    left: var(--spark-to, 33%);
    transform: scale(0.6);
    opacity: 0;
  }
}

/* ===== 新记录滑入 ===== */
.feed-item.just-added {
  animation: feedItemSlideIn 0.52s cubic-bezier(0.34, 1.56, 0.64, 1) both;
}

@keyframes feedItemSlideIn {
  0% {
    transform: translateY(-14rpx);
    opacity: 0;
    background: rgba(255, 232, 163, 0.35);
  }
  60% {
    background: rgba(255, 232, 163, 0.22);
  }
  100% {
    transform: translateY(0);
    opacity: 1;
    background: transparent;
  }
}

.sheet-divider {
  height: 2rpx;
  margin-top: 20rpx;
  background: #edf0f4;
}

.sheet-toolbar {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.sheet-tool {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  flex-shrink: 0;
  color: #9aa3b2;
  font-size: 42rpx;
  line-height: 42rpx;
  text-align: center;
}

.sheet-tool::before {
  content: "";
  position: absolute;
  left: 17rpx;
  top: 6rpx;
  width: 8rpx;
  height: 24rpx;
  border: 4rpx solid #9aa3b2;
  border-radius: 999rpx;
}

.sheet-tool::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 24rpx;
  width: 26rpx;
  height: 16rpx;
  border-bottom: 4rpx solid #9aa3b2;
  border-left: 4rpx solid #9aa3b2;
  border-right: 4rpx solid #9aa3b2;
  border-radius: 0 0 16rpx 16rpx;
}

.sheet-tool.voice.active,
.sheet-tool.voice.recognizing {
  color: #2d7d52;
}

.sheet-tool.voice.active::before,
.sheet-tool.voice.recognizing::before {
  border-color: #2d7d52;
}

.sheet-tool.voice.active::after,
.sheet-tool.voice.recognizing::after {
  border-color: #2d7d52;
}

.sheet-tool.voice.recognizing {
  opacity: 0.68;
}

.sheet-count {
  margin-left: auto;
  color: #9aa3b2;
  font-size: 26rpx;
  font-weight: 600;
}

.sheet-voice-status {
  min-height: 58rpx;
  margin-top: 12rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f1f5f1;
  color: #496457;
  font-size: 23rpx;
  line-height: 1.4;
}

.sheet-voice-status.recording {
  background: #f3eee7;
  color: #6f563d;
}

.voice-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: currentColor;
}

.sheet-voice-status.recording .voice-dot {
  animation: voicePulse 1s ease-in-out infinite;
}

.voice-tip {
  color: #9a8a7a;
}

.voice-time {
  margin-left: auto;
  font-variant-numeric: tabular-nums;
  color: #7e8795;
}

@keyframes voicePulse {
  0%,
  100% {
    opacity: 0.45;
    transform: scale(0.88);
  }

  50% {
    opacity: 1;
    transform: scale(1.18);
  }
}

.sheet-save {
  height: 112rpx;
  margin-top: 48rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #cfd6cf;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  transition: background 0.18s ease;
}

.sheet-save.active {
  background: linear-gradient(90deg, #7fa86d 0%, #2d6b4b 100%);
}

.sheet-save.loading {
  opacity: 0.72;
}

.sheet-submit-hint {
  margin-top: 18rpx;
  color: #8e98a7;
  font-size: 24rpx;
  text-align: center;
}
