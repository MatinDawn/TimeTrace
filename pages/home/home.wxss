.home-screen {
  padding-top: 0;
  padding-bottom: var(--screen-bottom-pad);
}

.custom-nav,
.scope-button,
.intro-row,
.quote-card,
.progress-total,
.hero-stage,
.hero-side,
.hero-hint-bar,
.tab-row {
  display: flex;
}

.custom-nav {
  position: relative;
  z-index: 3;
  align-items: center;
  justify-content: flex-start;
}

.nav-brand-title {
  position: absolute;
  left: 50%;
  bottom: 14rpx;
  transform: translateX(-50%);
  font-family: "PingFang SC", "Microsoft YaHei", sans-serif;
  font-size: 42rpx;
  line-height: 1.08;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: var(--ink-900);
}

.scope-button {
  align-items: center;
  gap: 12rpx;
  width: 240rpx;
  min-height: 72rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 249, 240, 0.88);
  border: 1rpx solid rgba(224, 206, 180, 0.3);
  box-shadow: 0 12rpx 28rpx rgba(105, 82, 59, 0.06);
}

.scope-sprout {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.sprout-stem {
  position: absolute;
  left: 14rpx;
  bottom: 3rpx;
  width: 3rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #7f9c67;
}

.sprout-leaf {
  position: absolute;
  width: 14rpx;
  height: 9rpx;
  border-radius: 14rpx 14rpx 0 14rpx;
  background: linear-gradient(180deg, #adc589 0%, #7f9c67 100%);
}

.sprout-left {
  left: 1rpx;
  top: 10rpx;
  transform: rotate(-36deg);
}

.sprout-right {
  right: 2rpx;
  top: 5rpx;
  transform: scaleX(-1) rotate(-36deg);
}

.scope-copy {
  min-width: 0;
  flex: 1;
}

.scope-button-label {
  font-size: 16rpx;
  color: var(--ink-300);
}

.scope-button-text {
  margin-top: 4rpx;
  max-width: 130rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 24rpx;
  font-weight: 600;
  color: #5b4b3d;
}

.scope-chevron {
  width: 12rpx;
  height: 12rpx;
  border-right: 2rpx solid #a08567;
  border-bottom: 2rpx solid #a08567;
  transform: rotate(45deg);
  margin-top: -6rpx;
}

.intro-row {
  margin-top: 28rpx;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.quote-card {
  flex: 1;
  min-width: 0;
  height: 132rpx;
  padding: 0;
  overflow: hidden;
  background: transparent;
  border: none;
  box-shadow: none;
}

.quote-plant {
  width: 100%;
}

.quote-plant-image {
  width: 520rpx;
  max-width: none;
  margin-left: -102rpx;
  margin-top: -18rpx;
  display: block;
}

.draft-entry {
  position: relative;
  min-width: 180rpx;
  min-height: 76rpx;
  padding: 0 22rpx 0 68rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  background: rgba(255, 248, 238, 0.92);
  border: 1rpx solid rgba(224, 206, 180, 0.34);
  color: #7f684d;
  font-size: 24rpx;
  box-shadow: 0 14rpx 34rpx rgba(111, 86, 59, 0.06);
}

.draft-icon {
  position: absolute;
  left: 16rpx;
  top: 50%;
  width: 48rpx;
  height: 48rpx;
  transform: translateY(-50%);
  display: block;
  flex-shrink: 0;
}

.draft-count {
  color: #ad9476;
}

.progress-card {
  margin-top: 24rpx;
  padding-bottom: 32rpx;
}

.progress-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.with-info {
  display: inline-flex;
  align-items: center;
  gap: 12rpx;
}

.info-dot {
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  font-size: 18rpx;
  color: #a89479;
  border: 2rpx solid rgba(192, 177, 155, 0.66);
}

.progress-bubble {
  width: 188rpx;
  padding: 14rpx 16rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(249, 239, 223, 0.92) 0%, rgba(244, 229, 208, 0.92) 100%);
  color: #7f6649;
  font-size: 21rpx;
  line-height: 1.55;
  flex-shrink: 0;
}

.progress-main {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  padding-right: 70rpx;
}

.progress-total {
  align-items: flex-end;
  gap: 10rpx;
  flex-wrap: wrap;
  color: var(--ink-900);
}

.progress-number {
  font-size: 64rpx;
  line-height: 1;
  color: var(--green-700);
}

.progress-separator,
.progress-target {
  font-size: 30rpx;
  line-height: 1.2;
}

.progress-unit {
  margin-left: 6rpx;
  font-size: 25rpx;
  line-height: 1.2;
}

.progress-track-shell {
  margin-top: 30rpx;
  padding: 0 36rpx;
}

.progress-track-line {
  position: relative;
  height: 124rpx;
  margin-top: 4rpx;
  border-radius: 999rpx;
}

.progress-track-line::before {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  top: 106rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #d9cdbc;
  transform: translateY(-50%);
}

.progress-segment {
  position: absolute;
  top: 106rpx;
  width: 50%;
  height: 4rpx;
  z-index: 1;
  border-radius: 999rpx;
  background: #d9cdbc;
  transform: translateY(-50%);
}

.progress-segment.left {
  left: 0;
}

.progress-segment.right {
  left: 50%;
}

.progress-segment.done {
  background: linear-gradient(90deg, #7fa86d 0%, #2d6b4b 100%);
}

.progress-node,
.progress-node-label,
.progress-indicator {
  position: absolute;
  transform: translate(-50%, -50%);
}

.progress-node {
  z-index: 3;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #fffaf2;
  border: 5rpx solid #d9cdbc;
  box-shadow: 0 6rpx 14rpx rgba(83, 63, 42, 0.08);
  top: 106rpx;
}

.progress-node.done {
  border-color: #72a061;
  background: #f3faee;
  box-shadow: 0 8rpx 18rpx rgba(45, 107, 75, 0.14);
}

.progress-node.left {
  left: 0;
}

.progress-node.right {
  left: 100%;
}

.progress-node.middle {
  left: 50%;
}

.progress-node-label {
  top: 134rpx;
  z-index: 3;
  color: #a18b73;
  font-size: 20rpx;
  line-height: 1;
  white-space: nowrap;
}

.progress-node-label.left {
  left: 0;
}

.progress-node-label.middle {
  left: 50%;
}

.progress-node-label.right {
  left: 100%;
}

.progress-indicator {
  z-index: 4;
  width: 64rpx;
  height: 64rpx;
  top: 76rpx;
  transition: left 0.24s ease;
  pointer-events: none;
}

.progress-mascot {
  position: absolute;
  inset: 0;
  overflow: visible;
}

.progress-mascot-image {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 54rpx;
  height: 68rpx;
  transform: translate(-50%, -70%);
}

.progress-tree-zone {
  position: absolute;
  right: 0;
  bottom: -28rpx;
  width: 76rpx;
  height: 112rpx;
  display: flex;
  align-items: flex-end;
  justify-content: flex-end;
}

.progress-tree-image {
  width: 76rpx;
  height: 112rpx;
}

.hero-card {
  margin-top: 24rpx;
}

.hero-stage {
  position: relative;
  min-height: 404rpx;
}

.hero-button {
  width: 356rpx;
  height: 356rpx;
  margin: 0 auto;
  border-radius: 50%;
  padding: 14rpx;
  background: linear-gradient(180deg, #f2d7b5 0%, #ddbf98 100%);
  box-shadow: 0 26rpx 52rpx rgba(103, 81, 53, 0.16);
  transition: transform 0.16s ease, box-shadow 0.16s ease;
}

.hero-button.recording {
  transform: scale(1.04);
  box-shadow:
    0 30rpx 60rpx rgba(45, 107, 75, 0.24),
    0 0 0 16rpx rgba(45, 107, 75, 0.08);
}

.hero-button-ring {
  width: 100%;
  height: 100%;
  padding: 12rpx;
  border-radius: 50%;
  background: rgba(255, 247, 235, 0.3);
}

.hero-button-inner {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding-top: 0;
  background: radial-gradient(circle at 30% 20%, #418960 0%, #2d6b4b 56%, #214c38 100%);
  color: #fffdf8;
  text-align: center;
}

.hero-leaf {
  width: 62rpx;
  height: 62rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.16);
}

.hero-leaf-core {
  position: relative;
  width: 23rpx;
  height: 32rpx;
  border-radius: 20rpx 20rpx 0 20rpx;
  background: #fffdf5;
  transform: rotate(-28deg);
}

.hero-leaf-core::after {
  content: "";
  position: absolute;
  left: 9rpx;
  top: 2rpx;
  width: 2rpx;
  height: 26rpx;
  background: rgba(45, 107, 75, 0.32);
  transform: rotate(28deg);
}

.hero-title {
  margin-top: 30rpx;
  width: 292rpx;
  padding: 0;
  font-family: "STKaiti", "Kaiti SC", "Songti SC", serif;
  font-size: 46rpx;
  font-weight: 700;
  line-height: 1.24;
  white-space: nowrap;
}

.hero-voice-status {
  max-width: 250rpx;
  min-height: 42rpx;
  margin-top: 16rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  background: rgba(255, 253, 248, 0.16);
  color: rgba(255, 253, 248, 0.92);
  font-size: 21rpx;
  line-height: 1.3;
  white-space: nowrap;
}

.hero-voice-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: currentColor;
  animation: voicePulse 1s ease-in-out infinite;
}

.hero-subtitle {
  display: none;
}

.hero-side {
  position: absolute;
  top: 134rpx;
  width: 124rpx;
  flex-direction: column;
  gap: 6rpx;
  color: #5f5144;
  font-size: 21rpx;
  line-height: 1.8;
}

.hero-side.left {
  left: 0;
}

.hero-side.right {
  right: 0;
  align-items: flex-end;
  text-align: right;
  width: 138rpx;
}

.hero-dashed {
  width: 48rpx;
  height: 22rpx;
  border-top: 3rpx dashed rgba(145, 122, 95, 0.8);
  border-right: 3rpx dashed rgba(145, 122, 95, 0.8);
  border-radius: 0 30rpx 0 0;
}

.hero-dashed.left {
  transform: rotate(10deg);
}

.hero-plane-image {
  width: 60rpx;
  margin-bottom: 6rpx;
}

.hero-hint-bar {
  margin-top: 22rpx;
  min-height: 80rpx;
  padding: 0 22rpx;
  align-items: center;
  justify-content: space-between;
  border-radius: 999rpx;
  background: rgba(252, 246, 235, 0.95);
  color: #7d694f;
  font-size: 23rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.75);
}

.hint-sprout {
  position: relative;
  width: 32rpx;
  height: 32rpx;
  flex-shrink: 0;
}

.hint-stem {
  position: absolute;
  left: 14rpx;
  bottom: 3rpx;
  width: 3rpx;
  height: 16rpx;
  background: #7ea05d;
  border-radius: 999rpx;
}

.hint-leaf {
  position: absolute;
  width: 13rpx;
  height: 8rpx;
  border-radius: 13rpx 13rpx 0 13rpx;
  background: linear-gradient(180deg, #a8c487 0%, #79995a 100%);
}

.hint-leaf.left {
  left: 2rpx;
  top: 10rpx;
  transform: rotate(-28deg);
}

.hint-leaf.right {
  right: 2rpx;
  top: 5rpx;
  transform: scaleX(-1) rotate(-28deg);
}

.hint-arrow {
  width: 14rpx;
  height: 14rpx;
  border-top: 2rpx solid #a48c6f;
  border-right: 2rpx solid #a48c6f;
  transform: rotate(45deg);
}

.overview-card {
  margin-top: 24rpx;
  padding-bottom: 42rpx;
}

.empty-text {
  position: relative;
  z-index: 1;
  margin-top: 24rpx;
  padding: 34rpx 24rpx;
  border-radius: 28rpx;
  background: rgba(249, 243, 233, 0.86);
  color: #8d7a65;
  font-size: 24rpx;
  line-height: 1.7;
  text-align: center;
}

.overview-pill {
  min-width: 90rpx;
  height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(247, 238, 224, 0.94);
  color: #9b8366;
  font-size: 23rpx;
}

.tab-row {
  gap: 16rpx;
  margin-top: 24rpx;
}

.feed-tab {
  flex: 1;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #f7eee0 0%, #efdfca 100%);
  color: #8a6f52;
  font-size: 24rpx;
  font-weight: 600;
}

.feed-tab.active {
  background: linear-gradient(180deg, #5a9670 0%, #2d6b4b 100%);
  color: #fffef8;
}

/* .feed-item 共性 (display/align/justify/gap/padding/border-bottom) 来自 .list-row */
.feed-item:last-of-type {
  border-bottom: none;
}

.feed-icon {
  width: 72rpx;
  height: 72rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(247, 238, 224, 0.95) 0%, rgba(240, 226, 205, 0.95) 100%);
  position: relative;
}

.feed-icon.sprout::before,
.feed-icon.sprout::after,
.feed-icon.hourglass::before,
.feed-icon.hourglass::after {
  content: "";
  position: absolute;
}

.feed-icon.sprout::before {
  left: 33rpx;
  top: 24rpx;
  width: 4rpx;
  height: 22rpx;
  background: #7ea05d;
}

.feed-icon.sprout::after {
  left: 20rpx;
  top: 14rpx;
  width: 28rpx;
  height: 18rpx;
  border-radius: 28rpx 28rpx 0 28rpx;
  background: linear-gradient(180deg, #99b876 0%, #73955a 100%);
  transform: rotate(-18deg);
}

.feed-icon.hourglass::before {
  left: 24rpx;
  top: 14rpx;
  width: 22rpx;
  height: 40rpx;
  border: 4rpx solid #b88b55;
  border-top-width: 6rpx;
  border-bottom-width: 6rpx;
  border-radius: 12rpx;
  transform: skewY(12deg);
}

.feed-icon.hourglass::after {
  left: 32rpx;
  top: 28rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #b88b55;
}

.feed-main {
  flex: 1;
  min-width: 0;
}

.feed-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #302821;
}

.feed-meta {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8d7a65;
}

.feed-side {
  flex-shrink: 0;
  max-width: 170rpx;
  text-align: right;
  font-size: 22rpx;
  font-weight: 600;
}

.feed-side.pending {
  color: #a27742;
}

.feed-side.done-amount {
  color: var(--green-700);
}

.feed-side.done-text {
  color: #7c9664;
}

.overview-quote {
  margin-top: 18rpx;
  text-align: center;
  font-size: 23rpx;
  line-height: 1.8;
  color: #6e5b48;
}

.overview-line-image {
  width: 116rpx;
  margin: 10rpx auto 0;
}

.overview-illustration {
  position: relative;
  z-index: 1;
  width: 100%;
  margin-top: 12rpx;
  display: block;
  border-radius: 28rpx;
}

.trace-sheet-mask {
  position: fixed;
  inset: 0;
  z-index: 80;
  display: flex;
  align-items: flex-end;
  background: rgba(29, 28, 25, 0.48);
  backdrop-filter: blur(14rpx);
}

.trace-sheet {
  width: 100%;
  min-height: 690rpx;
  padding: 46rpx 46rpx calc(54rpx + env(safe-area-inset-bottom));
  border-radius: 56rpx 56rpx 0 0;
  background: #ffffff;
  box-shadow: 0 -24rpx 70rpx rgba(29, 28, 25, 0.16);
}

.sheet-handle {
  width: 92rpx;
  height: 12rpx;
  margin: 0 auto 54rpx;
  border-radius: 999rpx;
  background: #e1e4e9;
}

.sheet-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
}

.sheet-title {
  flex: 1;
  min-width: 0;
  font-size: 38rpx;
  line-height: 1.2;
  font-weight: 800;
  color: #30343a;
}

.sheet-close {
  position: relative;
  width: 68rpx;
  height: 68rpx;
  flex-shrink: 0;
  border-radius: 50%;
  background: #f3f4f6;
}

.sheet-close::before,
.sheet-close::after {
  content: "";
  position: absolute;
  left: 22rpx;
  top: 32rpx;
  width: 26rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #6f7682;
}

.sheet-close::before {
  transform: rotate(45deg);
}

.sheet-close::after {
  transform: rotate(-45deg);
}

.sheet-editor {
  margin-top: 46rpx;
  padding: 34rpx 40rpx 26rpx;
  border-radius: 38rpx;
  background: #fbfbfc;
  box-shadow:
    0 14rpx 34rpx rgba(28, 31, 36, 0.08),
    inset 0 0 0 2rpx rgba(235, 238, 242, 0.8);
}

.sheet-textarea {
  width: 100%;
  height: 520rpx;
  color: #30343a;
  font-size: 30rpx;
  line-height: 1.7;
}

.sheet-textarea::placeholder {
  color: #9aa3b2;
}

.sheet-divider {
  height: 2rpx;
  margin-top: 20rpx;
  background: #edf0f4;
}

.sheet-toolbar {
  min-height: 72rpx;
  display: flex;
  align-items: center;
  gap: 30rpx;
}

.sheet-tool {
  position: relative;
  width: 42rpx;
  height: 42rpx;
  flex-shrink: 0;
  color: #9aa3b2;
  font-size: 42rpx;
  line-height: 42rpx;
  text-align: center;
}

.sheet-tool::before {
  content: "";
  position: absolute;
  left: 17rpx;
  top: 6rpx;
  width: 8rpx;
  height: 24rpx;
  border: 4rpx solid #9aa3b2;
  border-radius: 999rpx;
}

.sheet-tool::after {
  content: "";
  position: absolute;
  left: 8rpx;
  top: 24rpx;
  width: 26rpx;
  height: 16rpx;
  border-bottom: 4rpx solid #9aa3b2;
  border-left: 4rpx solid #9aa3b2;
  border-right: 4rpx solid #9aa3b2;
  border-radius: 0 0 16rpx 16rpx;
}

.sheet-tool.voice.active,
.sheet-tool.voice.recognizing {
  color: #2d7d52;
}

.sheet-tool.voice.active::before,
.sheet-tool.voice.recognizing::before {
  border-color: #2d7d52;
}

.sheet-tool.voice.active::after,
.sheet-tool.voice.recognizing::after {
  border-color: #2d7d52;
}

.sheet-tool.voice.recognizing {
  opacity: 0.68;
}

.sheet-count {
  margin-left: auto;
  color: #9aa3b2;
  font-size: 26rpx;
  font-weight: 600;
}

.sheet-voice-status {
  min-height: 58rpx;
  margin-top: 12rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #f1f5f1;
  color: #496457;
  font-size: 23rpx;
  line-height: 1.4;
}

.sheet-voice-status.recording {
  background: #f3eee7;
  color: #6f563d;
}

.voice-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: currentColor;
}

.sheet-voice-status.recording .voice-dot {
  animation: voicePulse 1s ease-in-out infinite;
}

.voice-tip {
  color: #9a8a7a;
}

.voice-time {
  margin-left: auto;
  font-variant-numeric: tabular-nums;
  color: #7e8795;
}

@keyframes voicePulse {
  0%,
  100% {
    opacity: 0.45;
    transform: scale(0.88);
  }

  50% {
    opacity: 1;
    transform: scale(1.18);
  }
}

.sheet-save {
  height: 112rpx;
  margin-top: 48rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #9db6a5;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
}

.sheet-save.loading {
  opacity: 0.72;
}

.sheet-submit-hint {
