.list-card {
  margin-top: 24rpx;
}

/* .category-row 共性 (display/align/justify/gap/padding/border-bottom + :last-child) 来自 .list-row */

.category-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-800);
}

.category-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--ink-500);
}

.action-group {
  display: flex;
  gap: 10rpx;
}

.delete {
  background: linear-gradient(180deg, #f6dfd7 0%, #f0d0c6 100%);
  color: #a85e49;
}
