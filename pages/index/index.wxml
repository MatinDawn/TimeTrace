<view class="dashboard-page">
  <view class="dashboard-hero">
    <view class="hero-title">留痕</view>
    <view class="hero-subtitle">每一笔收支，都有迹可循</view>
    <view class="hero-link" bindtap="goReport">查看完整统计</view>
  </view>

  <view class="card summary-card">
    <view class="card-head">
      <view class="card-title">数据统计总览</view>
      <view class="scope-tag">{{scopeLabel}}</view>
    </view>

    <view class="granularity-row">
      <view
        wx:for="{{granularityOptions}}"
        wx:key="key"
        class="granularity-chip {{selectedGranularity === item.key ? 'granularity-chip-active' : ''}}"
        data-value="{{item.key}}"
        bindtap="changeGranularity"
      >
        {{item.label}}
      </view>
    </view>

    <view class="scope-switcher">
      <view class="scope-nav" data-step="-1" bindtap="shiftScope">上一期</view>
      <picker wx:if="{{selectedGranularity !== 'year'}}" mode="date" value="{{selectedDate}}" bindchange="onPickDate">
        <view class="scope-center">选择{{pickerLabel}}：{{scopePickerText}}</view>
      </picker>
      <picker wx:else mode="selector" range="{{yearOptions}}" value="{{yearIndex}}" bindchange="onPickYear">
        <view class="scope-center">选择{{pickerLabel}}：{{scopePickerText}}</view>
      </picker>
      <view class="scope-nav" data-step="1" bindtap="shiftScope">下一期</view>
    </view>

    <view wx:if="{{hasRecords}}" class="summary-grid">
      <view class="summary-item">
        <view class="summary-label">{{metricPrefix}}支出</view>
        <view class="summary-value expense">¥{{summary.expense}}</view>
      </view>
      <view class="summary-item">
        <view class="summary-label">{{metricPrefix}}收入</view>
        <view class="summary-value income">¥{{summary.income}}</view>
      </view>
      <view class="summary-item">
        <view class="summary-label">{{metricPrefix}}结余</view>
        <view class="summary-value">¥{{summary.balance}}</view>
      </view>
      <view class="summary-item">
        <view class="summary-label">{{metricPrefix}}笔数</view>
        <view class="summary-value">{{summary.count}}</view>
      </view>
    </view>
    <view wx:else class="empty-block">
      <view class="empty-title">{{scopeLabel}}还没有账目</view>
      <view class="empty-text">从一句自然语言开始，比如“午饭花了 28 元”。</view>
    </view>
  </view>

  <view class="card trend-card">
    <view class="card-head">
      <view class="card-title">{{trendTitle}}</view>
      <view class="card-link" bindtap="goReport">更多统计</view>
    </view>
    <view wx:if="{{hasRecords}}" class="trend-chart">
      <view wx:for="{{trend}}" wx:key="label" class="trend-col">
        <view class="trend-bar-wrap">
          <view class="trend-bar" style="height: {{item.height}};"></view>
        </view>
        <view class="trend-amount">¥{{item.amount}}</view>
        <view class="trend-label">{{item.label}}</view>
      </view>
    </view>
    <view wx:else class="empty-block">
      <view class="empty-text">{{scopeLabel}}暂无数据，记账后这里会看到你的支出变化。</view>
    </view>
  </view>

  <view class="card recent-card">
    <view class="card-head">
      <view class="card-title">最近明细</view>
      <view class="card-link" bindtap="goRecords">查看全部</view>
    </view>
    <view wx:if="{{recentRecords.length}}">
      <view wx:for="{{recentRecords}}" wx:key="id" class="recent-item">
        <view class="recent-main">
          <view class="recent-title">{{item.categoryLabel}}</view>
          <view class="recent-note">{{item.note}}</view>
        </view>
        <view class="recent-side">
          <view class="recent-amount {{item.direction}}">
            {{item.direction === 'income' ? '+' : '-'}}¥{{item.amount}}
          </view>
          <view class="recent-date">{{item.date}}</view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-block">
      <view class="empty-text">{{scopeLabel}}还没有最近记录，先记一笔吧。</view>
    </view>
  </view>

  <view class="fab" bindtap="goLedger">记一笔</view>
</view>
