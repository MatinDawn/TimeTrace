.dashboard-page {
  min-height: 100vh;
  padding: 28rpx 24rpx 140rpx;
  box-sizing: border-box;
  background:
    radial-gradient(circle at top left, rgba(219, 229, 219, 0.95), transparent 34%),
    linear-gradient(180deg, #f6f1e8 0%, #eee5d7 100%);
}

.dashboard-hero {
  padding: 20rpx 8rpx 10rpx;
}

.hero-title {
  font-size: 52rpx;
  font-weight: 700;
  color: #20392f;
  letter-spacing: 2rpx;
}

.hero-subtitle {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #6c5d51;
}

.hero-link {
  margin-top: 18rpx;
  display: inline-block;
  color: #1f6b52;
  font-size: 24rpx;
}

.card {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 28rpx;
  background: rgba(255, 251, 245, 0.92);
  box-shadow: 0 14rpx 32rpx rgba(67, 52, 40, 0.08);
}

.card-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #2c241d;
}

.card-link {
  color: #1f6b52;
  font-size: 24rpx;
}

.scope-tag {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: #efe3d2;
  color: #5d493b;
  font-size: 22rpx;
}

.granularity-row {
  margin-top: 18rpx;
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
}

.granularity-chip {
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: #f4ebde;
  color: #735f4e;
  font-size: 24rpx;
}

.granularity-chip-active {
  background: #1f6b52;
  color: #fffdf8;
}

.picker-row {
  margin-top: 16rpx;
}

.picker-trigger {
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fbf5ec;
  color: #5e4d40;
  font-size: 24rpx;
}

.scope-switcher {
  margin-top: 16rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.scope-nav {
  padding: 18rpx 18rpx;
  border-radius: 18rpx;
  background: #f1e7da;
  color: #5d4a3c;
  font-size: 24rpx;
  white-space: nowrap;
}

.scope-center {
  flex: 1;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #fbf5ec;
  color: #5e4d40;
  font-size: 24rpx;
  text-align: center;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 16rpx;
  margin-top: 18rpx;
}

.summary-item {
  padding: 20rpx;
  border-radius: 20rpx;
  background: #fff7ea;
}

.summary-label {
  font-size: 24rpx;
  color: #826754;
}

.summary-value {
  margin-top: 8rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #2c241d;
}

.expense {
  color: #b14a37;
}

.income {
  color: #1f6b52;
}

.empty-block {
  margin-top: 18rpx;
  padding: 26rpx 20rpx;
  border-radius: 20rpx;
  background: #fbf5ec;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #3d3026;
}

.empty-text {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #7f6756;
}

.trend-chart {
  margin-top: 20rpx;
  display: flex;
  align-items: flex-end;
  gap: 12rpx;
  height: 280rpx;
}

.trend-col {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.trend-bar-wrap {
  width: 100%;
  height: 160rpx;
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.trend-bar {
  width: 30rpx;
  min-height: 12rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #d3a15f 0%, #1f6b52 100%);
}

.trend-amount {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #5f5042;
}

.trend-label {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #7d6856;
}

.recent-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(95, 80, 66, 0.08);
}

.recent-item:last-child {
  border-bottom: none;
  padding-bottom: 4rpx;
}

.recent-main {
  flex: 1;
  min-width: 0;
}

.recent-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2d241c;
}

.recent-note {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #816857;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.recent-side {
  margin-left: 16rpx;
  text-align: right;
}

.recent-amount {
  font-size: 30rpx;
  font-weight: 700;
}

.recent-date {
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #8a7262;
}

.fab {
  position: fixed;
  right: 28rpx;
  bottom: 34rpx;
  height: 94rpx;
  line-height: 94rpx;
  padding: 0 34rpx;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #1f6b52 0%, #174b3a 100%);
  color: #fffdf8;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 28rpx rgba(31, 107, 82, 0.22);
}
