<view class="page">
  <view class="hero">
    <view class="hero-title">全部明细</view>
    <view class="hero-subtitle">按时间倒序查看所有账目，方便你核对与整理最近的记录。</view>
  </view>

  <view class="section card" wx:if="{{records.length}}">
    <view
      class="record-item"
      wx:for="{{records}}"
      wx:key="id"
    >
      <view class="record-head">
        <view class="record-title">{{item.categoryLabel}} · {{item.note}}</view>
        <view class="record-amount {{item.direction}}">
          {{item.direction === 'income' ? '+' : '-'}}¥{{item.amount}}
        </view>
      </view>
      <view class="record-meta">{{item.date}} · {{item.rawText}}</view>
      <button class="secondary-btn" size="mini" data-id="{{item.id}}" bindtap="removeRecord">删除</button>
    </view>
  </view>

  <view wx:else class="section card">
    <view class="muted">还没有账目，先去“记一笔”录入第一条吧。</view>
  </view>
</view>
