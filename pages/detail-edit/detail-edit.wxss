.form-block,
.two-col,
.switch-row {
  margin-top: 24rpx;
}

.head-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.head-row .section-title {
  flex: 1;
  min-width: 0;
}

.created-chip {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(244, 235, 221, 0.9);
  color: var(--ink-500);
  font-size: 22rpx;
}

.creator-line {
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8d7256;
}

.parse-card {
  margin-top: 24rpx;
  padding: 22rpx 24rpx;
  border-radius: 26rpx;
  background: rgba(249, 242, 233, 0.95);
}

.parse-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.parse-copy {
  flex: 1;
  min-width: 0;
}

.parse-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.parse-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #2d6b4b;
  box-shadow: 0 0 0 10rpx rgba(45, 107, 75, 0.12);
}

.parse-dot-failed {
  background: #c27b56;
  box-shadow: 0 0 0 10rpx rgba(194, 123, 86, 0.12);
}

.parse-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--green-700);
}

.parse-tip,
.field-tip {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--ink-500);
}

.ghost-button-disabled,
.save-button-loading {
  opacity: 0.8;
}

.field-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #46392e;
}

.field-single,
.field-picker {
  display: flex;
  align-items: center;
}

.radio-row {
  display: block;
  margin-top: 18rpx;
  font-size: 26rpx;
  color: #5f5142;
}

.two-col {
  display: flex;
  gap: 16rpx;
}

.half {
  flex: 1;
  min-width: 0;
}

.switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 10rpx 0;
}

.switch-row > view:first-child {
  flex: 1;
  min-width: 0;
}

.save-button {
  width: 100%;
  margin-top: 34rpx;
}

.parse-orbit {
  position: relative;
  width: 64rpx;
  height: 64rpx;
  flex-shrink: 0;
  margin-right: 4rpx;
}

.parse-orbit-ring {
  position: absolute;
  inset: 0;
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  border: 3rpx solid rgba(45, 107, 75, 0.16);
  border-top-color: #2d6b4b;
  border-right-color: rgba(45, 107, 75, 0.45);
  animation: parseOrbit 1.4s linear infinite;
  box-sizing: border-box;
}

.parse-spark {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 8rpx;
  height: 8rpx;
  margin-left: -4rpx;
  margin-top: -4rpx;
  border-radius: 50%;
  background: #7da06f;
  box-shadow: 0 0 8rpx rgba(125, 160, 111, 0.6);
  transform-origin: 4rpx 32rpx;
  animation: parseOrbit 1.4s linear infinite;
}

.parse-spark.spark-1 {
  background: #2d6b4b;
  animation-duration: 1.4s;
  animation-delay: 0s;
}

.parse-spark.spark-2 {
  background: #7da06f;
  animation-duration: 1.4s;
  animation-delay: -0.46s;
}

.parse-spark.spark-3 {
  background: #c9b486;
  animation-duration: 1.4s;
  animation-delay: -0.93s;
}

.is-parsing .form-block,
.is-parsing .two-col {
  opacity: 0.5;
  pointer-events: none;
  filter: saturate(0.5);
  transition: opacity 0.3s ease, filter 0.3s ease;
}

.is-parsing .save-button {
  opacity: 0.5;
  pointer-events: none;
}

@keyframes parseOrbit {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
