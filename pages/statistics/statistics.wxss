.section-header,
.scope-toolbar,
.granularity-row,
.tab-row,
.stats-grid,
.trend-chart,
.mini-list-row {
  display: flex;
}

.statistics-screen {
  padding-bottom: var(--screen-bottom-pad);
}

.filter-card .section-header {
  display: block;
}

.filter-card .section-header > view:first-child {
  min-width: 0;
}

.scope-toolbar {
  position: relative;
  z-index: 1;
  width: 100%;
  margin-top: 22rpx;
  padding: 8rpx;
  align-items: center;
  gap: 10rpx;
  border-radius: 999rpx;
  background: rgba(248, 239, 225, 0.82);
}

.scope-icon {
  width: 62rpx;
  height: 62rpx;
  flex-shrink: 0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 251, 245, 0.92);
  color: #7d664d;
  font-size: 30rpx;
  font-weight: 700;
}

.scope-picker {
  flex: 1;
  min-width: 0;
}

.scope-pill {
  width: 100%;
  min-height: 62rpx;
  padding: 0 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: #fffaf3;
  color: #5d4f41;
  font-size: 25rpx;
  font-weight: 600;
}

.granularity-row {
  gap: 12rpx;
  margin-top: 22rpx;
}

.granularity-chip {
  flex: 1;
  min-width: 0;
  height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #f9efe1 0%, #efdfca 100%);
  color: #8a6f52;
  font-size: 24rpx;
  font-weight: 600;
}

.granularity-chip.active,
.stats-tab.active {
  background: linear-gradient(180deg, #5f966f 0%, #2d6b4b 100%);
  color: #fffef8;
}

.tab-row {
  flex-wrap: nowrap;
  gap: 12rpx;
  margin-top: 22rpx;
}

.stats-tab {
  flex: 1;
  min-width: 0;
  min-height: 66rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(248, 239, 225, 0.92);
  color: #8a6f52;
  font-size: 22rpx;
  font-weight: 600;
}

.stats-card {
  margin-top: 24rpx;
}

.stats-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: stretch;
  gap: 0;
}

.stats-box {
  width: 48%;
  flex: 0 0 48%;
  min-height: 156rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, rgba(250, 245, 238, 0.96) 0%, rgba(244, 236, 225, 0.94) 100%);
}

.stats-box:nth-child(2n) {
  margin-left: 0;
}

.stats-box:nth-child(n + 3) {
  margin-top: 18rpx;
}

.stats-label,
.stats-caption,
.trend-label,
.mini-list-row {
  color: #8f7b66;
}

.stats-label {
  font-size: 23rpx;
  line-height: 1.45;
}

.stats-value {
  margin-top: 12rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #2f271f;
}

.stats-caption {
  margin-top: 10rpx;
  font-size: 21rpx;
  line-height: 1.7;
}

.mini-list-title {
  margin-top: 28rpx;
  font-size: 27rpx;
  font-weight: 600;
  color: #4c4034;
}

.mini-list-row {
  justify-content: space-between;
  gap: 18rpx;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(110, 87, 58, 0.12);
  font-size: 24rpx;
}

.mini-list-row > view:first-child {
  min-width: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.mini-list-row > view:last-child {
  flex-shrink: 0;
}

.mini-list-row:last-child {
  border-bottom: none;
}

.trend-chart {
  align-items: flex-end;
  gap: 12rpx;
  height: 230rpx;
  margin-top: 24rpx;
  padding-top: 10rpx;
}

.trend-chart.small {
  height: 210rpx;
}

.trend-bar-wrap {
  flex: 1;
  min-width: 0;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
}

.trend-bar {
  width: 100%;
  min-height: 10rpx;
  border-radius: 18rpx 18rpx 0 0;
  background: linear-gradient(180deg, #a4c08c 0%, #2d6b4b 100%);
}

.trend-label {
  max-width: 100%;
  margin-top: 10rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  font-size: 20rpx;
}
