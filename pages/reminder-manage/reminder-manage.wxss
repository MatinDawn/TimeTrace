.list-card {
  margin-top: 24rpx;
}

.reminder-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(110, 87, 58, 0.12);
}

.reminder-row:last-child {
  border-bottom: none;
}

.reminder-main {
  flex: 1;
}

.reminder-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f271f;
}

.reminder-meta {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #8f7b66;
}
