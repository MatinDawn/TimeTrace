.mode-card {
  margin-top: 22rpx;
}

.mode-title,
.space-meta {
  font-size: 24rpx;
  color: var(--ink-500);
}

.mode-name {
  margin-top: 10rpx;
  font-family: "STKaiti", "Kaiti SC", "Songti SC", serif;
  font-size: 38rpx;
  font-weight: 700;
  color: var(--ink-800);
}

.mode-hint {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7f6a55;
}

.secondary-button,
.action-button,
.small-button {
  border: none;
}

.secondary-button,
.action-button {
  width: 100%;
  margin-top: 20rpx;
}

/* .space-item 共性 (display/align/justify/gap/padding/border-bottom + :last-child) 来自 .list-row */
.space-main {
  flex: 1;
}

.space-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.space-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--ink-800);
}

.active-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(227, 240, 231, 0.92);
  color: var(--green-700);
  font-size: 22rpx;
}

.small-button {
  flex-shrink: 0;
}
