.mode-card {
  margin-top: 22rpx;
}

.mode-title,
.space-meta {
  font-size: 24rpx;
  color: #8f7b66;
}

.mode-name {
  margin-top: 10rpx;
  font-family: "STKaiti", "Kaiti SC", "Songti SC", serif;
  font-size: 38rpx;
  font-weight: 700;
  color: #2f271f;
}

.mode-hint {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #7f6a55;
}

.secondary-button,
.action-button,
.small-button {
  border: none;
}

.secondary-button,
.action-button {
  width: 100%;
  margin-top: 20rpx;
}

.space-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--hairline);
}

.space-item:last-child {
  border-bottom: none;
}

.space-main {
  flex: 1;
}

.space-name-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.space-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #2f271f;
}

.active-tag {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(227, 240, 231, 0.92);
  color: #2d6b4b;
  font-size: 22rpx;
}

.small-button {
  flex-shrink: 0;
}
