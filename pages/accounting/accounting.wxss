.section-header,
.year-row,
.pool-grid,
.progress-meta,
.scope-toolbar,
.granularity-row,
.metrics-grid,
.trend-header,
.trend-chart,
.pie-layout,
.legend-row,
.legend-left,
.legend-right,
.finance-row {
  display: flex;
}

.accounting-screen {
  padding-bottom: var(--screen-bottom-pad);
}

.pool-card {
  margin-top: 0;
}

.analysis-card,
.finance-card {
  margin-top: 24rpx;
}

.pool-card .section-header,
.analysis-card .section-header,
.finance-card .section-header {
  gap: 18rpx;
}

.pool-card .section-header > view:first-child,
.analysis-card .section-header > view:first-child,
.finance-card .section-header > view:first-child {
  flex: 1;
  min-width: 0;
}

.year-row,
.progress-meta,
.finance-row,
.trend-header {
  align-items: center;
  justify-content: space-between;
}

.year-row {
  margin-top: 24rpx;
  gap: 16rpx;
}

.year-button,
.scope-icon {
  width: 66rpx;
  height: 66rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #f8efdf 0%, #efdcc4 100%);
  color: #7e6549;
  font-size: 28rpx;
  font-weight: 700;
}

.year-label {
  flex: 1;
  height: 66rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(248, 239, 225, 0.88);
  color: #5d4f41;
  font-size: 28rpx;
  font-weight: 600;
}

.pool-grid,
.metrics-grid {
  gap: 16rpx;
  margin-top: 24rpx;
}

.pool-item,
.metric-card {
  flex: 1;
  min-height: 142rpx;
  padding: 24rpx;
  border-radius: 26rpx;
  background: linear-gradient(180deg, rgba(250, 245, 238, 0.96) 0%, rgba(244, 236, 225, 0.94) 100%);
}

.pool-label,
.metric-label,
.progress-meta,
.empty-tip,
.legend-name,
.legend-amount,
.legend-percent,
.finance-meta,
.trend-amount {
  font-size: 22rpx;
  color: #907b66;
}

.pool-value,
.metric-value,
.pie-center-value {
  margin-top: 14rpx;
  font-size: 42rpx;
  font-weight: 700;
  color: #2f271f;
}

.progress-track {
  height: 18rpx;
  margin-top: 26rpx;
  border-radius: 999rpx;
  overflow: hidden;
  background: #e6dac8;
}

.progress-bar {
  height: 100%;
  border-radius: inherit;
  background: linear-gradient(90deg, #7ea05d 0%, #5f966f 40%, #2d6b4b 100%);
}

.progress-meta {
  margin-top: 14rpx;
}

.empty-tip {
  margin-top: 18rpx;
  line-height: 1.7;
}

.scope-toolbar {
  gap: 10rpx;
  align-items: center;
  flex-shrink: 0;
}

.scope-pill {
  min-width: 128rpx;
  min-height: 58rpx;
  padding: 0 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: rgba(248, 239, 225, 0.9);
  color: #7e6549;
  font-size: 24rpx;
}

.granularity-row {
  gap: 16rpx;
  margin-top: 24rpx;
}

.granularity-chip {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #f8efdf 0%, #efdcc4 100%);
  color: #8a6f52;
  font-size: 26rpx;
  font-weight: 600;
}

.granularity-chip.active {
  background: linear-gradient(180deg, #5f966f 0%, #2d6b4b 100%);
  color: #fffef8;
}

.trend-header {
  margin-top: 26rpx;
}

.trend-title,
.finance-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f271f;
}

.trend-chart {
  gap: 12rpx;
  align-items: flex-end;
  height: 300rpx;
  margin-top: 18rpx;
}

.trend-bar-wrap {
  flex: 1;
  height: 100%;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  align-items: center;
}

.trend-amount {
  margin-bottom: 10rpx;
}

.trend-bar {
  width: 100%;
  min-height: 12rpx;
  border-radius: 18rpx 18rpx 0 0;
  background: linear-gradient(180deg, #edc995 0%, #c98a5f 100%);
}

.trend-label {
  margin-top: 12rpx;
  font-size: 20rpx;
  color: #9b8770;
}

.pie-layout {
  margin-top: 24rpx;
  gap: 22rpx;
  align-items: center;
}

.pie-shell {
  position: relative;
  width: 240rpx;
  height: 240rpx;
  flex-shrink: 0;
}

.pie-chart {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  box-shadow: inset 0 0 0 10rpx rgba(255, 255, 255, 0.36);
}

.pie-center {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 124rpx;
  height: 124rpx;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  background: rgba(255, 250, 243, 0.96);
}

.pie-center-label {
  font-size: 20rpx;
  color: #907b66;
}

.pie-center-value {
  margin-top: 8rpx;
  font-size: 28rpx;
}

.pie-legend {
  flex: 1;
  min-width: 0;
}

.legend-row {
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 0;
}

.legend-left,
.legend-right {
  align-items: center;
  gap: 10rpx;
}

.legend-dot {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
}

.finance-row {
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(110, 87, 58, 0.12);
}

.finance-row > view:first-child {
  flex: 1;
  min-width: 0;
}

.finance-row:last-child {
  border-bottom: none;
}
