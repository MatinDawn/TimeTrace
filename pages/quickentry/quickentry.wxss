.composer-card {
  margin-top: 24rpx;
}

.composer-input-wrap,
.voice-input-wrap {
  min-height: 320rpx;
  border-radius: 28rpx;
  background: rgba(255, 250, 243, 0.9);
}

.record-textarea {
  width: 100%;
  height: 320rpx;
  padding: 26rpx;
  font-size: 28rpx;
  color: var(--ink-800);
}

.voice-input-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
}

.voice-hint {
  font-size: 28rpx;
  font-weight: 600;
  color: #4a3f33;
}

.voice-button {
  min-width: 320rpx;
  height: 94rpx;
  margin-top: 24rpx;
  padding: 0 28rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(180deg, #5f966f 0%, #2d6b4b 100%);
  color: #fffef8;
  font-size: 28rpx;
}

.voice-tip {
  margin-top: 18rpx;
  font-size: 22rpx;
  line-height: 1.7;
  color: #8f7b66;
  text-align: center;
}

.composer-toolbar {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 18rpx;
}

.toolbar-text,
.submit-hint {
  font-size: 24rpx;
  color: var(--ink-500);
}

.example-title {
  margin-top: 28rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #4c4034;
}

.example-list {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 16rpx;
}

.example-chip {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(247, 236, 222, 0.96);
  color: #7f684e;
  font-size: 24rpx;
}

.save-button {
  width: 100%;
  margin-top: 30rpx;
}

.save-button-loading {
  opacity: 0.86;
}

.submit-hint {
  margin-top: 14rpx;
  text-align: center;
}
