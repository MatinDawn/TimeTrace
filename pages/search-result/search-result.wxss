.search-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 24rpx;
}

.search-button {
  flex-shrink: 0;
}

.list-card {
  margin-top: 24rpx;
}

.result-row {
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(110, 87, 58, 0.12);
}

.result-row:last-child {
  border-bottom: none;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #2f271f;
}

.result-meta,
.result-content {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #8f7b66;
}
