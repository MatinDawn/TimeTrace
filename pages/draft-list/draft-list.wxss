.action-card {
  display: flex;
  gap: 16rpx;
}

.batch-button {
  flex: 1;
}

.list-card {
  margin-top: 24rpx;
}

.draft-screen .section-header > view:first-child {
  flex: 1;
  min-width: 0;
}

.draft-item {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--hairline);
}

.draft-item:last-child {
  border-bottom: none;
}

.draft-main {
  flex: 1;
  min-width: 0;
}

.draft-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-800);
}

.draft-meta,
.draft-content {
  margin-top: 8rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: var(--ink-500);
}

.select-mark {
  width: 42rpx;
  height: 42rpx;
  margin-top: 4rpx;
  flex-shrink: 0;
  border-radius: 50%;
  border: 2rpx solid #c3ac91;
  display: flex;
  align-items: center;
  justify-content: center;
}

.select-mark.active {
  border-color: #2d6b4b;
  background: rgba(95, 150, 111, 0.16);
}

.select-inner {
  width: 18rpx;
  height: 18rpx;
  border-radius: 50%;
  background: transparent;
}

.select-mark.active .select-inner {
  background: #2d6b4b;
}
