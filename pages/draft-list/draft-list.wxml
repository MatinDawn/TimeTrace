<view class="screen draft-screen">
  <view class="card">
    <view class="section-header">
      <view>
        <view class="section-title">{{ui.title}}</view>
        <view class="section-subtitle">{{ui.subtitle}}</view>
      </view>
      <view class="mini-button" bindtap="toggleManageMode">{{manageMode ? ui.done : ui.manage}}</view>
    </view>
    <input class="search-input" placeholder="{{ui.searchPlaceholder}}" value="{{keyword}}" bindinput="onSearchInput" />
  </view>

  <view class="card list-card">
    <view wx:if="{{drafts.length}}">
      <view wx:for="{{drafts}}" wx:key="id" class="list-row draft-item" data-id="{{item.id}}" bindlongpress="enterManageWithSelection">
        <view wx:if="{{manageMode}}" class="select-mark {{selectedIds.indexOf(item.id) >= 0 ? 'active' : ''}}" catchtap="toggleSelect" data-id="{{item.id}}">
          <view class="select-inner"></view>
        </view>
        <view class="draft-main" bindtap="handleDraftTap" data-id="{{item.id}}" data-mode="{{item.aiParseStatus === 'pending' || item.aiParseStatus === 'failed' ? 'remoteDraft' : 'normal'}}">
          <view class="draft-title-row">
            <view class="draft-title">{{item.actionName || ui.improve}}</view>
            <view wx:if="{{!manageMode}}" class="mini-button draft-delete" catchtap="removeDraft" data-id="{{item.id}}">{{ui.delete}}</view>
          </view>
          <view class="draft-meta">{{ui.sourceText}} {{ui.separator}} {{item.draftSource}} {{ui.separator}} {{ui.timeText}} {{ui.separator}} {{item.recordTime || item.createdAtDisplay}}</view>
          <view class="draft-meta">{{ui.categoryText}} {{ui.separator}} {{item.categoryName || ui.improve}}</view>
          <view class="draft-content">{{item.originalContent}}</view>
        </view>
      </view>
    </view>
    <view wx:else class="empty-card">{{ui.empty}}</view>
  </view>

  <view class="batch-bottom-bar {{manageMode && selectedIds.length ? 'visible' : ''}}">
    <view class="selected-count">{{ui.selected}} {{selectedIds.length}} {{ui.itemUnit}}</view>
    <view class="batch-actions">
      <view class="batch-icon-button category" bindtap="batchChangeCategory">
        <text class="batch-icon">🏷️</text>
        <text>{{ui.categoryAction}}</text>
      </view>
      <view class="batch-icon-button danger" bindtap="batchDelete">
        <text class="batch-icon">🗑️</text>
        <text>{{ui.deleteAction}}</text>
      </view>
    </view>
  </view>
</view>
